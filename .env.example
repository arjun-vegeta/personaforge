# ElevenLabs API Key
ELEVENLABS_API_KEY=your_elevenlabs_key

# Google Gemini API Key
GOOGLE_API_KEY=your_gemini_key

# Optional: Database URL (Defaults to local sqlite for CLI if not set)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/personaforge

# Optional: Redis URL (Required for workers)
# REDIS_URL=redis://localhost:6379
